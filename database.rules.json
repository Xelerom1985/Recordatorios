{
  "rules": {
    "recordatorios": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "tokens": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "config": {
      "$uid": {
        ".read": "auth != null && auth.uid === $uid",
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "recordatorios_compartidos": {
      ".read": "auth != null && root.child('config_compartido/miembros').child(auth.uid).val() === true",
      ".write": "auth != null && root.child('config_compartido/miembros').child(auth.uid).val() === true"
    },
    "config_compartido": {
      "miembros": {
        ".read": "auth != null"
      }
    }
  }
}
